{
  "name": "LeadRoutingFlow",
  "description": "Routes new leads from Dataverse to the appropriate sales representative based on territory.",
  "trigger": {
    "type": "WhenARowIsAdded",
    "table": "cr_leads"
  },
  "actions": [
    {
      "name": "ConditionTerritory",
      "type": "Condition",
      "expression": "@or(equals(triggerOutputs()?['body/cr_territory'], 'North India'), equals(triggerOutputs()?['body/cr_territory'], 'West India'))",
      "ifTrue": {
        "actions": [
          {
            "name": "AssignOwner",
            "type": "UpdateRow",
            "table": "cr_leads",
            "recordId": "@triggerOutputs()?['body/cr_leadid']",
            "changes": {
              "ownerid@odata.bind": "systemusers(amit-desai-id-1234)"
            }
          },
          {
            "name": "SendEmailNotification",
            "type": "SendEmailV2",
            "to": "north-west-sales@company.in",
            "subject": "New Lead Assigned",
            "body": "A new lead has been assigned to your territory. Please check the PowerApp dashboard."
          }
        ]
      },
      "ifFalse": {
        "actions": [
          {
            "name": "AssignDefaultOwner",
            "type": "UpdateRow",
            "table": "cr_leads",
            "recordId": "@triggerOutputs()?['body/cr_leadid']",
            "changes": {
              "ownerid@odata.bind": "systemusers(central-queue-id-5678)"
            }
          }
        ]
      }
    }
  ]
}
