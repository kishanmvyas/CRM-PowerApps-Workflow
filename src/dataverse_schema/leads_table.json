{
  "tableName": "cr_lead",
  "displayName": "Lead",
  "description": "Custom table to store incoming sales leads.",
  "columns": [
    {
      "logicalName": "cr_leadid",
      "displayName": "Lead",
      "type": "Uniqueidentifier",
      "isPrimaryId": true
    },
    {
      "logicalName": "cr_fullname",
      "displayName": "Full Name",
      "type": "String",
      "maxLength": 100,
      "isPrimaryName": true
    },
    {
      "logicalName": "cr_email",
      "displayName": "Email Address",
      "type": "String",
      "maxLength": 100
    },
    {
      "logicalName": "cr_territory",
      "displayName": "Territory",
      "type": "Picklist",
      "options": ["North India", "South India", "East India", "West India"]
    },
    {
      "logicalName": "cr_status",
      "displayName": "Review Status",
      "type": "Status",
      "options": ["New", "Contacted", "Qualified", "Disqualified"]
    }
  ]
}
